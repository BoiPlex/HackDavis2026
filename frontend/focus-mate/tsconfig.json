{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.jsx"
  ],
  "compilerOptions": {
    "allowJs": true,
    "paths": {
      "~*": [
        "./*"
      ]
    },
    "baseUrl": ".",
    "ignoreDeprecations": "6.0"
  }
}
